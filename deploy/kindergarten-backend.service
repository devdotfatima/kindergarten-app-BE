[Unit]
Description=Kindergarten Backend (Gunicorn)
After=network.target postgresql.service

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/kindergarten-app-BE/core
ExecStart=/home/ubuntu/kindergarten-app-BE/core/venv/bin/gunicorn core.wsgi:application --bind 0.0.0.0:8000 --workers 3 --timeout 120
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
